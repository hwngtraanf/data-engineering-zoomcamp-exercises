docker run -it --rm \
  -e POSTGRES_USER="root" \
  -e POSTGRES_PASSWORD="root" \
  -e POSTGRES_DB="ny_taxi" \
  -v ny_taxi_postgres_data:/var/lib/postgresql \
  -p 5432:5432 \
  --network=pg-network \
  --name pgdatabase \
  postgres:18


docker run -it --rm \
  --network=pg-network \
  taxi_ingest:v001 \
  --pg_host=pgdatabase \
  --year=2021 \
  --month=1 \
  --chunk_size=100000 \
  --target_table=yellow_taxi_data_2021_1


docker run -it --rm \
  --network=pipeline_default \
  taxi_ingest:v001 \
  --pg_host=pgdatabase \
  --year=2021 \
  --month=1 \
  --chunk_size=100000 \
  --target_table=yellow_taxi_data_2021_1


docker run -it \
  -e PGADMIN_DEFAULT_EMAIL="admin@admin.com" \
  -e PGADMIN_DEFAULT_PASSWORD="root" \
  -v pgadmin_data:/var/lib/pgadmin \
  -p 8085:80 \
  --network=pg-network \
  --name pgadmin \
  dpage/pgadmin4